# Email settings (for quote form → Tommie's inbox)
# Use Gmail: enable App Passwords at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Where quote emails are delivered (Tommie's email)
TOMMIE_EMAIL=tommie@bluefinaircon.com.au

# Stripe (get keys from https://dashboard.stripe.com/apikeys)
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY

# Your site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.bluefinaircon.com.au

# Admin panel credentials
ADMIN_USERNAME=your-admin-username
# Generate a bcrypt hash of your chosen password:
# Run in terminal: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
ADMIN_PASSWORD_HASH=$2b$10$REPLACE_WITH_REAL_BCRYPT_HASH

# Admin session cookie secret — any random 32+ character string
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string-at-least-32-chars
